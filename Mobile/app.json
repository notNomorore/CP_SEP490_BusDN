{
  "expo": {
    "name": "BusDN",
    "slug": "busdn-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "busdn",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#f2fcf8"
      }
    }
  }
}
